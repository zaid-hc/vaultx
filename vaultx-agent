#!/usr/bin/env python3
"""Entry point for the VaultX AI agent.

Run directly:
    ./vaultx-agent [options]

Or via the Python module:
    python -m agent.cli [options]
"""
import sys
import os

# Ensure the repo root (directory containing this script) is on sys.path so
# that the `agent` package is importable regardless of the working directory.
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if _SCRIPT_DIR not in sys.path:
    sys.path.insert(0, _SCRIPT_DIR)

from agent.cli import main  # noqa: E402

if __name__ == "__main__":
    main()
