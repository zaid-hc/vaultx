# ---------- Sanitize Subcommand ----------

# Sensitive key names matched case-insensitively
SANITIZE_SENSITIVE_PATTERN='^(token|auth_token|api_key|secret|client_secret|kms_key|kms_key_id|private_key|password|access_key|secret_key)$'

# Address/URL key names that should have their hostname DNS-anonymized
SANITIZE_ADDR_PATTERN='^(vault_addr|api_addr|cluster_addr|cluster_address|address|redirect_addr)$'

# mask_ipv6_inner <addr>
# Partially masks an IPv6 address string (no brackets), keeping the last hextet readable.
# All prior hextets are replaced with 'x', preserving '::' compressed notation.
#   2001:db8::1           -> x:x::1
#   fd00:abcd::10         -> x:x::10
#   2001:db8:0:0:0:0:0:1  -> x:x:x:x:x:x:x:1
mask_ipv6_inner() {
  local addr="$1"

  # Get the last hextet (segment after the final colon)
  local last="${addr##*:}"

  if [[ "$addr" == *"::"* ]]; then
    # Compressed form — split on the first "::"
    local before_dc="${addr%%::*}"
    local after_dc="${addr#*::}"

    # Mask all groups in before_dc
    local masked_before=""
    if [[ -n "$before_dc" ]]; then
      local t="$before_dc"
      while [[ "$t" == *":"* ]]; do
        masked_before="${masked_before}x:"
        t="${t#*:}"
      done
      masked_before="${masked_before}x"
    fi

    # Mask all groups in after_dc except the last hextet
    local masked_after="$last"
    if [[ "$after_dc" == *":"* ]]; then
      local after_prefix="${after_dc%:*}"
      local masked_after_prefix=""
      local t="$after_prefix"
      while [[ "$t" == *":"* ]]; do
        masked_after_prefix="${masked_after_prefix}x:"
        t="${t#*:}"
      done
      masked_after_prefix="${masked_after_prefix}x"
      masked_after="${masked_after_prefix}:${last}"
    fi

    if [[ -n "$masked_before" ]]; then
      echo "${masked_before}::${masked_after}"
    else
      echo "::${masked_after}"
    fi
  else
    # Full (uncompressed) form — mask all groups except the last
    local result=""
    local t="$addr"
    while [[ "$t" == *":"* ]]; do
      result="${result}x:"
      t="${t#*:}"
    done
    echo "${result}${last}"
  fi
}

# mask_host <host>
# Masks a bare hostname/IP for address sanitization.
#   IPv4               -> x.x.x.<last-octet>
#   DNS 2-label        -> unchanged  (e.g., hashicorp.com -> hashicorp.com)
#   DNS 3+ labels      -> replace each subdomain label with x
#                         (e.g., prd.ec2.hashicorp.com -> x.x.hashicorp.com)
#   Single-label       -> x
#   localhost/127.0.0.1/0.0.0.0/::1/:: -> unchanged
#   IPv6               -> [x:x::last] (partial mask, last hextet preserved)
mask_host() {
  local host="$1"

  # Strip IPv6 brackets for inspection
  local inner_host="$host"
  if [[ "$host" == "["*"]" ]]; then
    inner_host="${host:1:${#host}-2}"
  fi

  # Loopback / localhost / wildcard bind: preserve as-is
  if [[ "$inner_host" == "localhost" || "$inner_host" == "127.0.0.1" || \
        "$inner_host" == "::1"       || "$inner_host" == "0.0.0.0"   || \
        "$inner_host" == "::" ]]; then
    echo "$host"
    return 0
  fi

  # IPv4: keep last octet only
  if [[ "$inner_host" =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]]; then
    echo "x.x.x.${BASH_REMATCH[4]}"
    return 0
  fi

  # IPv6 (contains two or more colons — IPv6 requires at least "::" or multiple ":"):
  # A plain host:port has exactly one colon, so this check correctly excludes those.
  # Partially mask: keep last hextet, replace prior hextets with x.
  if [[ "$inner_host" == *":"*":"* ]]; then
    local masked
    masked=$(mask_ipv6_inner "$inner_host")
    echo "[${masked}]"
    return 0
  fi

  # DNS/FQDN: replace each subdomain label with x, preserve the registrable domain
  # (last two labels, e.g., hashicorp.com).
  if [[ "$inner_host" == *"."* ]]; then
    local tld="${inner_host##*.}"          # last label (TLD)
    local without_tld="${inner_host%.*}"   # all labels except TLD
    local sld="${without_tld##*.}"         # second-to-last label (SLD)

    # 2-label domain (e.g., hashicorp.com): already the registrable domain, no subdomain to mask
    if [[ "$without_tld" != *"."* ]]; then
      echo "$inner_host"
      return 0
    fi

    # 3+ labels: build an x. prefix for every subdomain label (all but the last two labels)
    local subdomain_part="${without_tld%.*}"  # everything before the SLD
    local prefix="x."
    local temp="$subdomain_part"
    while [[ "$temp" == *"."* ]]; do
      prefix="${prefix}x."
      temp="${temp#*.}"
    done

    echo "${prefix}${sld}.${tld}"
    return 0
  fi

  # Single-label hostname
  echo "x"
}

# mask_addr_value <value>
# Masks an address value: parses URL scheme/port/path and masks only the host.
# Handles: URL (scheme://host[:port][/path]), host:port, [IPv6]:port, plain host.
mask_addr_value() {
  local value="$1"

  # URL with scheme://
  if [[ "$value" == *"://"* ]]; then
    local scheme="${value%%://*}"
    local after_scheme="${value#*://}"

    # Split authority (host[:port]) from path/query/fragment
    local authority path_and_rest
    if [[ "$after_scheme" =~ ^([^/?#]*)(.*)$ ]]; then
      authority="${BASH_REMATCH[1]}"
      path_and_rest="${BASH_REMATCH[2]}"
    else
      authority="$after_scheme"
      path_and_rest=""
    fi

    # Separate host from optional port (handles IPv6 brackets)
    local host port_str=""
    if [[ "$authority" =~ ^\[([^\]]*)\](:[0-9]+)?$ ]]; then
      host="[${BASH_REMATCH[1]}]"
      port_str="${BASH_REMATCH[2]:-}"
    elif [[ "$authority" =~ ^([^:]+)(:[0-9]+)?$ ]]; then
      host="${BASH_REMATCH[1]}"
      port_str="${BASH_REMATCH[2]:-}"
    else
      host="$authority"
    fi

    local masked_host
    masked_host=$(mask_host "$host")
    echo "${scheme}://${masked_host}${port_str}${path_and_rest}"
    return 0
  fi

  # Bracketed IPv6 host with optional port: [addr] or [addr]:port
  if [[ "$value" =~ ^\[([^\]]+)\](:[0-9]+)?$ ]]; then
    local inner="${BASH_REMATCH[1]}"
    local port_str="${BASH_REMATCH[2]:-}"
    local masked
    masked=$(mask_host "[$inner]")
    echo "${masked}${port_str}"
    return 0
  fi

  # host:port — plain IPv4 or DNS with a numeric port (single colon, port all-digits)
  if [[ "$value" =~ ^([^:]+):([0-9]+)$ ]]; then
    local host="${BASH_REMATCH[1]}"
    local port="${BASH_REMATCH[2]}"
    local masked
    masked=$(mask_host "$host")
    echo "${masked}:${port}"
    return 0
  fi

  # Plain host (no scheme, no port)
  mask_host "$value"
}

# Keep the old name as an alias so existing call-sites remain valid.
mask_vault_addr() { mask_addr_value "$@"; }

# sanitize_line <line>
# Processes one line of a config file: redacts sensitive keys, masks vault_addr.
sanitize_line() {
  local line="$1"

  # Pass through comment lines unchanged
  if [[ "$line" =~ ^[[:space:]]*# ]]; then
    echo "$line"
    return 0
  fi

  # Match:  [indent] key [spaces] = [spaces] value
  local re='^([[:space:]]*)([a-zA-Z_][a-zA-Z0-9_]*)([[:space:]]*)=([[:space:]]*)(.*)'
  if [[ "$line" =~ $re ]]; then
    local indent="${BASH_REMATCH[1]}"
    local key="${BASH_REMATCH[2]}"
    local sp1="${BASH_REMATCH[3]}"
    local sp2="${BASH_REMATCH[4]}"
    local val="${BASH_REMATCH[5]}"
    local key_lower="${key,,}"

    # Address/URL keys: mask hostname (not fully redact)
    if [[ "$key_lower" =~ $SANITIZE_ADDR_PATTERN ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_addr_value "$val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # Sensitive keys: fully redact
    if [[ "$key_lower" =~ $SANITIZE_SENSITIVE_PATTERN ]]; then
      local suffix=""
      if [[ "$val" =~ ^\"[^\"]*\"(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\"${suffix}"
      elif [[ "$val" =~ ^\'[^\']*\'(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}'***REDACTED***'${suffix}"
      else
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\""
      fi
      return 0
    fi
  fi

  echo "$line"
}

# sanitize_config <file>
# Reads a config file line by line and sanitizes each line.
sanitize_config() {
  local file="$1"
  while IFS= read -r line || [[ -n "$line" ]]; do
    sanitize_line "$line"
  done < "$file"
}

show_sanitize_help() {
  cat << EOF
Usage:
  vaultx sanitize -config=<file> [-out=<file>]
  vaultx sanitize <file>         [-out=<file>]

Sanitize sensitive values in a Vault config file so it can be safely shared
with support teams. Outputs to stdout by default.

ARGUMENTS:
  <file>              Path to the config file to sanitize (positional)
  -config=<file>      Path to the config file to sanitize (flag form)

OPTIONS:
  -out=<file>         Write sanitized output to FILE instead of stdout
  -help               Show this help message

REDACTED KEYS (replaced with ***REDACTED***):
  token, auth_token, api_key, secret, client_secret,
  kms_key, kms_key_id, private_key, password, access_key, secret_key
  (matching is case-insensitive)

ADDRESS MASKING (host DNS-anonymized, structure preserved):
  Applies to: vault_addr, api_addr, cluster_addr, cluster_address, address,
              redirect_addr  (matched case-insensitively)

  IPv4 host:       169.182.4.100               ->  x.x.x.100
  DNS 2-label:     hashicorp.com               ->  hashicorp.com  (unchanged)
  DNS 3-label:     vault.hashicorp.com         ->  x.hashicorp.com
  DNS 4-label:     prd.ec2.hashicorp.com       ->  x.x.hashicorp.com
  URL:             https://vault.hashicorp.com:8200/v1
                                               ->  https://x.hashicorp.com:8200/v1
  host:port:       prd.ec2.hashicorp.com:8201  ->  x.x.hashicorp.com:8201
  Loopback:        localhost / 127.0.0.1 / 0.0.0.0  ->  unchanged
  IPv6:            [2001:db8::1]               ->  [REDACTED_IPv6]
                   (IPv6 loopback ::1 is preserved; all other IPv6 hosts are fully redacted)

NOTE: Log sanitization is planned for a future release.

EXAMPLES:
  vaultx sanitize -config=config.hcl
  vaultx sanitize config.hcl
  vaultx sanitize -config=config.hcl -out=sanitized.hcl
EOF
}

cmd_sanitize() {
  local config_file="" out_file=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -config=*|--config=*) config_file="${1#*=}" ;;
      -config|--config) shift; config_file="$1" ;;
      -out=*|--out=*) out_file="${1#*=}" ;;
      -out|--out) shift; out_file="$1" ;;
      -help|--help) show_sanitize_help; exit 0 ;;
      -*)
        echo "ERROR: Unknown sanitize flag: $1" >&2
        show_sanitize_help >&2
        exit 1
        ;;
      *)
        if [[ -z "$config_file" ]]; then
          config_file="$1"
        else
          echo "ERROR: Unexpected argument: $1" >&2
          show_sanitize_help >&2
          exit 1
        fi
        ;;
    esac
    shift
  done

  if [[ -z "$config_file" ]]; then
    echo "ERROR: No config file specified." >&2
    show_sanitize_help >&2
    exit 1
  fi

  if [[ ! -e "$config_file" ]]; then
    echo "ERROR: Config file not found: $config_file" >&2
    exit 1
  fi

  if [[ ! -f "$config_file" ]]; then
    echo "ERROR: Not a regular file: $config_file" >&2
    exit 1
  fi

  if [[ ! -r "$config_file" ]]; then
    echo "ERROR: Config file is not readable: $config_file" >&2
    exit 1
  fi

  if [[ -n "$out_file" ]]; then
    sanitize_config "$config_file" > "$out_file"
    echo "Sanitized config written to: $out_file" >&2
  else
    sanitize_config "$config_file"
  fi
}

# Handle subcommands before global flag parsing
if [[ "${1:-}" == "sanitize" ]]; then
  shift
  cmd_sanitize "$@"
  exit $?
fi

while [[ "$#" -gt 0 ]]; do
  case $1 in
    -format=json) JSON_FORMAT=true ;; 
    -export=*) EXPORT_FILE="${1#*=}" ;;
    -help|--help) show_help; exit 0 ;;
    *) echo "Unknown parameter passed: $1"; show_help; exit 1 ;;
  esac
  shift
done

handle_vault_connection() {
  # Check VAULT_ADDR
  if [[ -z "${VAULT_ADDR:-}" ]]; then
    read -p "Enter Vault address (e.g., http://127.0.0.1:8200): " VAULT_ADDR
    [[ -z "$VAULT_ADDR" ]] && error_exit "Vault address is required"
  else
    if [[ "$JSON_FORMAT" = false ]]; then echo "Using VAULT_ADDR from environment variable: $VAULT_ADDR" | color "$GREEN"; fi
  fi
  export VAULT_ADDR
  log "INFO" "Vault address set to: $VAULT_ADDR"

  # Check VAULT_TOKEN
  if [[ -z "${VAULT_TOKEN:-}" ]]; then
    read -sp "Enter your Vault token: " VAULT_TOKEN; echo ""
    [[ -z "$VAULT_TOKEN" ]] && error_exit "Vault token is required"
  else
    if [[ "$JSON_FORMAT" = false ]]; then echo "Using VAULT_TOKEN from environment variable." | color "$GREEN"; fi
  fi
  export VAULT_TOKEN
  log "INFO" "Vault token provided"

  # Validate connection
  if ! VAULT_TOKEN=$VAULT_TOKEN vault token lookup -format=json >/dev/null 2>&1; then
    error_exit "Invalid Vault token or connection failed. Please check VAULT_ADDR ($VAULT_ADDR) and VAULT_TOKEN"
  fi
  log "INFO" "Vault connection validated successfully"
}

parse_raft_list_peers_cli() {
  local output
  output=$(VAULT_TOKEN=$VAULT_TOKEN vault operator raft list-peers 2>&1) || return 1
  local parsed_output='['; local first_row=true; local in_header=true
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ "$in_header" = true ]]; then
      [[ "$line" == *"----"* ]] && in_header=false
      continue
    fi
    local node=$(echo "$line" | awk '{print $1}')
    local address=$(echo "$line" | awk '{print $2}')
    local state=$(echo "$line" | awk '{print $3}')
    local voter=$(echo "$line" | awk '{print $4}')
    [[ "$first_row" = false ]] && parsed_output+=','
    first_row=false
    parsed_output+='{"node":"'"$node"'","address":"'"$address"'","state":"'"$state"'","voter":"'"$voter"'"}'
  done <<< "$output"
  parsed_output+=']'
  echo "$parsed_output" | jq '.' >/dev/null 2>&1 || return 1
  echo "$parsed_output"
}

get_raft_list_peers() {
  log "DEBUG" "Getting Raft peers list"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "=== Raft List Peers ===" | color "$RED"
    if ! VAULT_TOKEN=$VAULT_TOKEN vault operator raft list-peers 2>&1 | colorize_raft_list_peers; then
      echo "Failed to get Raft peers" | color "$RED"
    fi
    echo ""
  else
    local cli_parsed
    if cli_parsed=$(parse_raft_list_peers_cli); then
      local formatted
      formatted=$(jq -n --argjson data "$cli_parsed" '{"cli_parsed": $data}' 2>/dev/null) || formatted=""
      echo "${formatted:-{}}"; return
    fi
    local output formatted
    if ! output=$(VAULT_TOKEN=$VAULT_TOKEN vault operator raft list-peers -format=json 2>&1); then
      echo "{}"
    else
      formatted=$(echo "$output" | jq '.' 2>/dev/null) || formatted=""
      echo "${formatted:-{}}"
    fi
  fi
}

colorize_raft_list_peers() {
  while IFS= read -r line; do
    if [[ $line == "Node"* || $line == "----"* ]]; then
      echo "$line" | color "$YELLOW"
    else
      node=$(echo "$line" | awk '{print $1}')
      address=$(echo "$line" | awk '{print $2}')
      state=$(echo "$line" | awk '{print $3}')
      voter=$(echo "$line" | awk '{print $4}')
      if [[ $state == "leader" ]]; then
        printf "%-10s %-21s %-11s %-5s\n" "$node" "$address" "$state" "$voter" | color "$PINK"
      else
        printf "%-10s %-21s %-11s %-5s\n" "$node" "$address" "$state" "$voter" | color "$GREEN"
      fi
    fi
  done
}

discover_nodes() {
  [[ "$JSON_FORMAT" = false ]] && echo "Discovering Vault cluster nodes..." | color "$BLUE"
  nodes_output=$(VAULT_TOKEN=$VAULT_TOKEN vault operator members -format=json | jq -r '.Nodes[].api_address' 2>/dev/null) || error_exit "Failed to discover nodes"
  NODES=()
  while IFS= read -r node; do [[ -n "$node" ]] && NODES+=("$node"); done <<< "$nodes_output"
  [[ ${#NODES[@]} -eq 0 ]] && error_exit "No Vault nodes discovered"
  log "INFO" "Discovered ${#NODES[@]} nodes"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "Discovered nodes:" | color "$BLUE"
    for NODE in "${NODES[@]}"; do echo "$NODE" | color "$YELLOW"; done
  fi
}

get_vault_status() {
  local node="$1"; log "DEBUG" "Getting status for node: $node"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "=== Vault Status for $node ===" | color "$RED"
    if ! VAULT_ADDR=$node VAULT_TOKEN=$VAULT_TOKEN vault status 2>&1 | colorize_vault_status; then
      echo "Failed to get status for $node" | color "$RED"
    fi
    echo ""
  else
    local output formatted
    output=$(VAULT_ADDR=$node VAULT_TOKEN=$VAULT_TOKEN vault status -format=json 2>&1) || true
    formatted=$(echo "$output" | jq '.' 2>/dev/null) || formatted=""
    echo "${formatted:-{}}"
  fi
}

colorize_vault_status() {
  while IFS= read -r line; do
    if [[ $line == "Key"* || $line == "---"* ]]; then
      echo "$line" | color "$YELLOW"
    else
      key=$(echo "$line" | awk -F'[ ]{2,}' '{print $1}')
      value=$(echo "$line" | awk -F'[ ]{2,}' '{print $2}')
      printf "%-40s" "$key" | color "$BLUE"; printf "%s\n" "$value" | color "$GREEN"
    fi
  done
}

get_vault_operator_members() {
  log "DEBUG" "Getting Vault operator members"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "=== Vault Operator Members ===" | color "$RED"
    if ! VAULT_TOKEN=$VAULT_TOKEN vault operator members 2>&1 | colorize_vault_operator_members; then
      echo "Failed to get Vault operator members" | color "$RED"
    fi
    echo ""
  else
    local output formatted
    if ! output=$(VAULT_TOKEN=$VAULT_TOKEN vault operator members -format=json 2>&1); then
      echo "{\"Nodes\": []}"
    else
      formatted=$(echo "$output" | jq '.' 2>/dev/null) || formatted=""
      echo "${formatted:-{\"Nodes\": []}}"
    fi
  fi
}

colorize_vault_operator_members() {
  while IFS= read -r line; do
    if [[ $line == "Host Name"* || $line == "---------"* ]]; then
      echo "$line" | color "$YELLOW"
    else
      host_name=$(echo "$line" | awk '{print $1}')
      api_address=$(echo "$line" | awk '{print $2}')
      cluster_address=$(echo "$line" | awk '{print $3}')
      active_node=$(echo "$line" | awk '{print $4}')
      version=$(echo "$line" | awk '{print $5}')
      upgrade_version=$(echo "$line" | awk '{print $6}')
      redundancy_zone=$(echo "$line" | awk '{print $7}')
      last_echo=$(echo "$line" | awk '{print $8}')
      if [[ $active_node == "true" ]]; then
        printf "%-18s %-30s %-30s %-12s %-9s %-17s %-17s %-20s\n" \
          "$host_name" "$api_address" "$cluster_address" "$active_node" "$version" "$upgrade_version" "$redundancy_zone" "$last_echo" | color "$PINK"
      else
        printf "%-18s %-30s %-30s %-12s %-9s %-17s %-17s %-20s\n" \
          "$host_name" "$api_address" "$cluster_address" "$active_node" "$version" "$upgrade_version" "$redundancy_zone" "$last_echo" | color "$GREEN"
      fi
    fi
  done
}

get_vault_license() {
  log "DEBUG" "Getting Vault license"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "=== Vault License ===" | color "$RED"
    if ! VAULT_TOKEN=$VAULT_TOKEN vault license get 2>&1 | colorize_vault_license; then
      echo "Failed to get Vault license" | color "$RED"
    fi
    echo ""
  else
    local output formatted
    output=$(VAULT_TOKEN=$VAULT_TOKEN vault license get -format=json 2>&1) || true
    formatted=$(echo "$output" | jq '.data.autoloaded // {}' 2>/dev/null) || formatted=""
    echo "${formatted:-{}}"
  fi
}

colorize_vault_license() {
  while IFS= read -r line; do
    if [[ $line == "Key"* || $line == "---"* ]]; then
      echo "$line" | color "$YELLOW"
    else
      key=$(echo "$line" | awk '{print $1}')
      value=$(echo "$line" | awk '{sub($1 FS, ""); print}')
      if [[ -z "$value" ]]; then echo "$line" | color "$BLUE"
      else echo -n "$key " | color "$BLUE"; echo "$value" | color "$GREEN"; fi
    fi
  done
}

get_raft_autopilot_state() {
  log "DEBUG" "Getting Raft autopilot state"
  if [[ "$JSON_FORMAT" = false ]]; then
    echo "=== Raft Autopilot State ===" | color "$RED"
    if ! VAULT_TOKEN=$VAULT_TOKEN vault operator raft autopilot state 2>&1 | colorize_autopilot_state; then
      echo "Failed to get Raft autopilot state" | color "$RED"
    fi
    echo ""
  else
    local output formatted
    output=$(VAULT_TOKEN=$VAULT_TOKEN vault operator raft autopilot state -format=json 2>&1) || true
    formatted=$(echo "$output" | jq '.' 2>/dev/null) || formatted=""
    echo "${formatted:-{}}"
  fi
}

colorize_autopilot_state() {
  while IFS= read -r line; do
    if [[ $line == "Voters:"* || $line == "Servers:"* || $line == "Upgrade Info:"* ]]; then
      echo "$line" | color "$YELLOW"
    elif [[ $line == *":"* ]]; then
      key=$(echo "$line" | awk -F: '{print $1}')
      value=$(echo "$line" | awk -F: '{print $2}' | sed 's/^[[:space:]]*//')
      echo -n "${key}:" | color "$BLUE"; echo " ${value}" | color "$GREEN"
    elif [[ $line == *" "* ]]; then
      echo "$line" | color "$GREEN"
    else
      echo "$line"
    fi
  done
}

