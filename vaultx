#!/usr/bin/env bash

# VaultX - Vault Cluster Diagnostic Tool
# Exit on error, pipe failures
set -o pipefail

# Define colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color
PINK='\033[0;35m'

# Default configuration
LOG_LEVEL="INFO"
LOG_FILE="${HOME}/.vaultx.log"

# ---------- Logging ----------

log() {
  local level="$1"; local message="$2"; local timestamp
  timestamp=$(date "+%Y-%m-%d %H:%M:%S")
  local level_num
  case "$level" in
    DEBUG) level_num=0;; INFO) level_num=1;; WARN) level_num=2;; ERROR) level_num=3;; *) level_num=1;;
  esac
  local config_level_num
  case "$LOG_LEVEL" in
    DEBUG) config_level_num=0;; INFO) config_level_num=1;; WARN) config_level_num=2;; ERROR) config_level_num=3;; *) config_level_num=1;;
  esac
  if [[ $level_num -ge $config_level_num ]]; then
    echo "[$timestamp] [$level] $message" >> "$LOG_FILE"
    [[ "$level" = "ERROR" ]] && echo "[$level] $message" >&2
  fi
}

error_exit() { log "ERROR" "$1"; echo -e "${RED}ERROR: $1${NC}" >&2; cleanup; exit 1; }

cleanup() {
  log "DEBUG" "Running cleanup"
  if [[ -n "${temp_files[@]:-}" ]]; then rm -f "${temp_files[@]}" 2>/dev/null || true; fi
}
trap cleanup EXIT

is_piped() { [[ ! -t 1 ]]; }
color() { 
  if is_piped; then 
    cat
  else 
    echo -en "$1"
    cat
    echo -en "$NC"
  fi
}

check_dependencies() {
  log "INFO" "Checking dependencies"
  local missing_deps=()
  for cmd in vault jq; do
    command -v "$cmd" >/dev/null 2>&1 || missing_deps+=("$cmd")
  done
  [[ ${#missing_deps[@]} -gt 0 ]] && error_exit "Missing required dependencies: ${missing_deps[*]}"
  log "INFO" "All dependencies satisfied"
}

JSON_FORMAT=false
EXPORT_FILE=""

show_help() {
  cat << EOF
VaultX - A diagnostic tool for HashiCorp Vault clusters

USAGE:
  vaultx [OPTIONS]
  vaultx sanitize -config=<file> [-out=<file>]

OPTIONS:
  -format=json       Output in JSON format (pretty-printed)
  -export=FILE       Export data to specified file
  -help              Show this help message

SUBCOMMANDS:
  sanitize           Sanitize sensitive values in a config file

EXAMPLES:
  vaultx                              # Colorized CLI output
  vaultx -format=json                 # Pretty-printed JSON output to stdout
  vaultx -export=diagnostics.json     # Export to file
  vaultx sanitize -config=config.hcl  # Sanitize a config file (output to stdout)
  vaultx sanitize config.hcl          # Positional form

DESCRIPTION:
  VaultX collects comprehensive diagnostic information from your Vault cluster
  including node status, Raft configuration, license info, replication status,
  and more. Perfect for generating support tickets or troubleshooting.

ENVIRONMENT VARIABLES:
  VAULT_ADDR         Vault server address (e.g., http://127.0.0.1:8200)
  VAULT_TOKEN        Vault authentication token
EOF
}

# ---------- Sanitize Subcommand ----------

# ================================================================================
# SANITIZE POLICY MATRIX
# ================================================================================
# Field category       | Matched keys (case-insensitive)          | Applied policy
# ---------------------|------------------------------------------|-----------------
# secret/full-redact   | token, auth_token, api_key, secret,      | ***REDACTED***
#                      | client_secret, kms_key, kms_key_id,      |
#                      | private_key, password, access_key,       |
#                      | secret_key                               |
# endpoint/anonymize   | vault_addr, api_addr, cluster_addr,      | mask host
#                      | cluster_address, address, redirect_addr  | (DNS/IPv4/IPv6)
# path/tail-preserve   | path, tls_cert_file, tls_key_file,       | .../.../dir/file
#                      | tls_client_ca_file, tls_ca_file,         |
#                      | ca_cert, ca_path, cert_file, key_file,   |
#                      | pid_file, log_file, file_path,           |
#                      | audit_log_path, config_file              |
# identifier/token-mask| cluster_name, node_id, node_name,        | x-x-suffix
#                      | region, availability_zone                |
# generic-fallback     | any other key — classified by key name   | redact if secret-
#                      | or value content                         | like; mask addr/
#                      |                                          | path/ident by val
# ================================================================================

# Sensitive key names matched case-insensitively
SANITIZE_SENSITIVE_PATTERN='^(token|auth_token|api_key|secret|client_secret|kms_key|kms_key_id|private_key|password|access_key|secret_key)$'

# Address/URL key names that should have their hostname DNS-anonymized
SANITIZE_ADDR_PATTERN='^(vault_addr|api_addr|cluster_addr|cluster_address|address|redirect_addr)$'

# File-path key names: tail-preserving masking (keep last two path segments)
SANITIZE_PATH_PATTERN='^(path|tls_cert_file|tls_key_file|tls_client_ca_file|tls_ca_file|ca_cert|ca_path|cert_file|key_file|pid_file|log_file|file_path|audit_log_path|config_file)$'

# Resource-identifier key names: delimiter-aware token masking
SANITIZE_IDENT_PATTERN='^(cluster_name|node_id|node_name|region|availability_zone)$'

# mask_ipv6_inner <addr>
# Partially masks an IPv6 address string (no brackets), keeping the last hextet readable.
# All prior hextets are replaced with 'x', preserving '::' compressed notation.
#   2001:db8::1           -> x:x::1
#   fd00:abcd::10         -> x:x::10
#   2001:db8:0:0:0:0:0:1  -> x:x:x:x:x:x:x:1
mask_ipv6_inner() {
  local addr="$1"

  # Get the last hextet (segment after the final colon)
  local last="${addr##*:}"

  if [[ "$addr" == *"::"* ]]; then
    # Compressed form — split on the first "::"
    local before_dc="${addr%%::*}"
    local after_dc="${addr#*::}"

    # Mask all groups in before_dc
    local masked_before=""
    if [[ -n "$before_dc" ]]; then
      local t="$before_dc"
      while [[ "$t" == *":"* ]]; do
        masked_before="${masked_before}x:"
        t="${t#*:}"
      done
      masked_before="${masked_before}x"
    fi

    # Mask all groups in after_dc except the last hextet
    local masked_after="$last"
    if [[ "$after_dc" == *":"* ]]; then
      local after_prefix="${after_dc%:*}"
      local masked_after_prefix=""
      local t="$after_prefix"
      while [[ "$t" == *":"* ]]; do
        masked_after_prefix="${masked_after_prefix}x:"
        t="${t#*:}"
      done
      masked_after_prefix="${masked_after_prefix}x"
      masked_after="${masked_after_prefix}:${last}"
    fi

    if [[ -n "$masked_before" ]]; then
      echo "${masked_before}::${masked_after}"
    else
      echo "::${masked_after}"
    fi
  else
    # Full (uncompressed) form — mask all groups except the last
    local result=""
    local t="$addr"
    while [[ "$t" == *":"* ]]; do
      result="${result}x:"
      t="${t#*:}"
    done
    echo "${result}${last}"
  fi
}

# mask_host <host>
# Masks a bare hostname/IP for address sanitization.
#   IPv4               -> x.x.x.<last-octet>
#   DNS 2-label        -> unchanged  (e.g., hashicorp.com -> hashicorp.com)
#   DNS 3+ labels      -> replace each subdomain label with x
#                         (e.g., prd.ec2.hashicorp.com -> x.x.hashicorp.com)
#   Single-label       -> x
#   localhost/127.0.0.1/0.0.0.0/::1/:: -> unchanged
#   IPv6               -> [x:x::last] (partial mask, last hextet preserved)
mask_host() {
  local host="$1"

  # Strip IPv6 brackets for inspection
  local inner_host="$host"
  if [[ "$host" == "["*"]" ]]; then
    inner_host="${host:1:${#host}-2}"
  fi

  # Loopback / localhost / wildcard bind: preserve as-is
  if [[ "$inner_host" == "localhost" || "$inner_host" == "127.0.0.1" || \
        "$inner_host" == "::1"       || "$inner_host" == "0.0.0.0"   || \
        "$inner_host" == "::" ]]; then
    echo "$host"
    return 0
  fi

  # IPv4: keep last octet only
  if [[ "$inner_host" =~ ^([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})\.([0-9]{1,3})$ ]]; then
    echo "x.x.x.${BASH_REMATCH[4]}"
    return 0
  fi

  # IPv6 (contains two or more colons — IPv6 requires at least "::" or multiple ":"):
  # A plain host:port has exactly one colon, so this check correctly excludes those.
  # Partially mask: keep last hextet, replace prior hextets with x.
  if [[ "$inner_host" == *":"*":"* ]]; then
    local masked
    masked=$(mask_ipv6_inner "$inner_host")
    echo "[${masked}]"
    return 0
  fi

  # DNS/FQDN: replace each subdomain label with x, preserve the registrable domain
  # (last two labels, e.g., hashicorp.com).
  if [[ "$inner_host" == *"."* ]]; then
    local tld="${inner_host##*.}"          # last label (TLD)
    local without_tld="${inner_host%.*}"   # all labels except TLD
    local sld="${without_tld##*.}"         # second-to-last label (SLD)

    # 2-label domain (e.g., hashicorp.com): already the registrable domain, no subdomain to mask
    if [[ "$without_tld" != *"."* ]]; then
      echo "$inner_host"
      return 0
    fi

    # 3+ labels: build an x. prefix for every subdomain label (all but the last two labels)
    local subdomain_part="${without_tld%.*}"  # everything before the SLD
    local prefix="x."
    local temp="$subdomain_part"
    while [[ "$temp" == *"."* ]]; do
      prefix="${prefix}x."
      temp="${temp#*.}"
    done

    echo "${prefix}${sld}.${tld}"
    return 0
  fi

  # Single-label hostname
  echo "x"
}

# mask_addr_value <value>
# Masks an address value: parses URL scheme/port/path and masks only the host.
# Handles: URL (scheme://host[:port][/path]), host:port, [IPv6]:port, plain host.
mask_addr_value() {
  local value="$1"

  # URL with scheme://
  if [[ "$value" == *"://"* ]]; then
    local scheme="${value%%://*}"
    local after_scheme="${value#*://}"

    # Split authority (host[:port]) from path/query/fragment
    local authority path_and_rest
    if [[ "$after_scheme" =~ ^([^/?#]*)(.*)$ ]]; then
      authority="${BASH_REMATCH[1]}"
      path_and_rest="${BASH_REMATCH[2]}"
    else
      authority="$after_scheme"
      path_and_rest=""
    fi

    # Separate host from optional port (handles IPv6 brackets)
    local host port_str=""
    if [[ "$authority" =~ ^\[([^\]]*)\](:[0-9]+)?$ ]]; then
      host="[${BASH_REMATCH[1]}]"
      port_str="${BASH_REMATCH[2]:-}"
    elif [[ "$authority" =~ ^([^:]+)(:[0-9]+)?$ ]]; then
      host="${BASH_REMATCH[1]}"
      port_str="${BASH_REMATCH[2]:-}"
    else
      host="$authority"
    fi

    local masked_host
    masked_host=$(mask_host "$host")
    echo "${scheme}://${masked_host}${port_str}${path_and_rest}"
    return 0
  fi

  # Bracketed IPv6 host with optional port: [addr] or [addr]:port
  if [[ "$value" =~ ^\[([^\]]+)\](:[0-9]+)?$ ]]; then
    local inner="${BASH_REMATCH[1]}"
    local port_str="${BASH_REMATCH[2]:-}"
    local masked
    masked=$(mask_host "[$inner]")
    echo "${masked}${port_str}"
    return 0
  fi

  # host:port — plain IPv4 or DNS with a numeric port (single colon, port all-digits)
  if [[ "$value" =~ ^([^:]+):([0-9]+)$ ]]; then
    local host="${BASH_REMATCH[1]}"
    local port="${BASH_REMATCH[2]}"
    local masked
    masked=$(mask_host "$host")
    echo "${masked}:${port}"
    return 0
  fi

  # Plain host (no scheme, no port)
  mask_host "$value"
}

# Keep the old name as an alias so existing call-sites remain valid.
mask_vault_addr() { mask_addr_value "$@"; }

# mask_path_value <path>
# Tail-preserving path masking: keep the last two path segments, replace each
# preceding segment with '...'.  Works for both Unix and Windows paths.
#   /etc/ssl/vault/server.key         ->  .../.../vault/server.key
#   /opt/vault/tls/tls.crt            ->  .../.../tls/tls.crt
#   /opt/vault/data                   ->  .../vault/data
#   /vault/data  or  vault/data       ->  unchanged (<=2 segments)
#   C:\vault\tls\server.key           ->  ...\tls\server.key
mask_path_value() {
  local value="$1"
  [[ -z "$value" ]] && echo "$value" && return 0

  # Detect delimiter (backslash = Windows path)
  local delim="/"
  if [[ "$value" == *"\\"* && "$value" != *"/"* ]]; then
    delim="\\"
  fi

  # Normalize to forward slashes for splitting, then restore delimiter in output
  local norm="${value//\\//}"

  # Strip leading slash or Windows drive letter prefix
  local rest="${norm#/}"
  if [[ "$rest" =~ ^[A-Za-z]: ]]; then
    rest="${rest:3}"
  fi

  IFS='/' read -ra _parts <<< "$rest"

  # Filter empty segments (e.g. from trailing slash)
  local parts=()
  for _p in "${_parts[@]}"; do
    [[ -n "$_p" ]] && parts+=("$_p")
  done
  local n=${#parts[@]}

  # Two or fewer segments: no leading directories to mask
  if [[ $n -le 2 ]]; then
    echo "$value"
    return 0
  fi

  # Build '...<delim>' prefix — one '...' per masked segment
  local keep_from=$(( n - 2 ))
  local prefix=""
  for (( _i=0; _i<keep_from; _i++ )); do
    prefix="${prefix}...${delim}"
  done

  # Build kept tail using original delimiter
  local kept="${parts[$keep_from]}"
  for (( _i=keep_from+1; _i<n; _i++ )); do
    kept="${kept}${delim}${parts[$_i]}"
  done

  echo "${prefix}${kept}"
}

# mask_identifier_value <identifier>
# Delimiter-aware token masking for resource identifiers.
# Uses the first delimiter found: '-' takes priority over '_'.
# Rule: keep the last ceil(N/2) tokens, replace the first floor(N/2) with 'x'.
# Single-token or no-delimiter values are returned unchanged.
#   vault-prod-eu-west-1   ->  x-x-eu-west-1   (N=5, keep 3, mask 2)
#   prod-cluster-01        ->  x-cluster-01     (N=3, keep 2, mask 1)
#   my_app_prod_us_east    ->  x_x_prod_us_east (N=5, keep 3, mask 2)
#   production             ->  production       (no delimiter)
mask_identifier_value() {
  local value="$1"

  local delim=""
  if [[ "$value" == *"-"* ]]; then
    delim="-"
  elif [[ "$value" == *"_"* ]]; then
    delim="_"
  else
    echo "$value"
    return 0
  fi

  IFS="$delim" read -ra tokens <<< "$value"
  local n=${#tokens[@]}

  if [[ $n -le 1 ]]; then
    echo "$value"
    return 0
  fi

  local keep=$(( (n + 1) / 2 ))
  local mask=$(( n - keep ))

  # Nothing to mask (shouldn't happen for n>=2 but guard anyway)
  if [[ $mask -eq 0 ]]; then
    echo "$value"
    return 0
  fi

  local result=""
  for (( _i=0; _i<mask; _i++ )); do
    result="${result}x${delim}"
  done

  result="${result}${tokens[$mask]}"
  for (( _i=mask+1; _i<n; _i++ )); do
    result="${result}${delim}${tokens[$_i]}"
  done

  echo "$result"
}

# sanitize_line <line> [in_secret]
# Processes one line of a config file: redacts sensitive keys, masks vault_addr.
# in_secret=1 when the line is inside a 'secret' stanza; causes 'path' to be
# fully redacted instead of tail-preserved.
sanitize_line() {
  local line="$1"
  local in_secret="${2:-0}"

  # Pass through comment lines unchanged
  if [[ "$line" =~ ^[[:space:]]*# ]]; then
    echo "$line"
    return 0
  fi

  # Match:  [indent] key [spaces] = [spaces] value
  local re='^([[:space:]]*)([a-zA-Z_][a-zA-Z0-9_]*)([[:space:]]*)=([[:space:]]*)(.*)'
  if [[ "$line" =~ $re ]]; then
    local indent="${BASH_REMATCH[1]}"
    local key="${BASH_REMATCH[2]}"
    local sp1="${BASH_REMATCH[3]}"
    local sp2="${BASH_REMATCH[4]}"
    local val="${BASH_REMATCH[5]}"
    local key_lower="${key,,}"

    # Address/URL keys: mask hostname (not fully redact)
    if [[ "$key_lower" =~ $SANITIZE_ADDR_PATTERN ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_addr_value "$val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # Sensitive keys: fully redact
    if [[ "$key_lower" =~ $SANITIZE_SENSITIVE_PATTERN ]]; then
      local suffix=""
      if [[ "$val" =~ ^\"[^\"]*\"(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\"${suffix}"
      elif [[ "$val" =~ ^\'[^\']*\'(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}'***REDACTED***'${suffix}"
      else
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\""
      fi
      return 0
    fi

    # Path keys: tail-preserving masking (keep last two path segments).
    # Special case: 'path' inside a 'secret' stanza is fully redacted because
    # the Vault secret path is itself sensitive information.
    if [[ "$key_lower" =~ $SANITIZE_PATH_PATTERN ]]; then
      if [[ "$key_lower" == "path" && "$in_secret" == "1" ]]; then
        local suffix=""
        if [[ "$val" =~ ^\"[^\"]*\"(.*)$ ]]; then
          suffix="${BASH_REMATCH[1]}"
          echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\"${suffix}"
        elif [[ "$val" =~ ^\'[^\']*\'(.*)$ ]]; then
          suffix="${BASH_REMATCH[1]}"
          echo "${indent}${key}${sp1}=${sp2}'***REDACTED***'${suffix}"
        else
          echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\""
        fi
        return 0
      fi
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_path_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_path_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_path_value "$val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # Resource identifier keys: delimiter-aware token masking
    if [[ "$key_lower" =~ $SANITIZE_IDENT_PATTERN ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_identifier_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_identifier_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_identifier_value "$val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # Generic fallback: classify unrecognised keys by key name or value content.
    # Extract the raw (unquoted) value for content-based classification.
    local raw_val
    if [[ "$val" =~ ^\"([^\"]*)\" ]]; then
      raw_val="${BASH_REMATCH[1]}"
    elif [[ "$val" =~ ^\'([^\']*)\' ]]; then
      raw_val="${BASH_REMATCH[1]}"
    else
      raw_val="$val"
    fi

    # 5a. Key name implies a secret → full redact
    if [[ "$key_lower" =~ (^|_)(token|secret|password|passwd|credential)(s?)($|_) ]] || \
       [[ "$key_lower" =~ (^|_)key$ ]]; then
      local suffix=""
      if [[ "$val" =~ ^\"[^\"]*\"(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\"${suffix}"
      elif [[ "$val" =~ ^\'[^\']*\'(.*)$ ]]; then
        suffix="${BASH_REMATCH[1]}"
        echo "${indent}${key}${sp1}=${sp2}'***REDACTED***'${suffix}"
      else
        echo "${indent}${key}${sp1}=${sp2}\"***REDACTED***\""
      fi
      return 0
    fi

    # 5b. Value looks like an endpoint / URL / IP → addr masking
    if [[ "$raw_val" == *"://"* ]] || \
       [[ "$raw_val" =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3} ]] || \
       [[ "$raw_val" =~ ^[a-zA-Z][a-zA-Z0-9-]*(\.[a-zA-Z][a-zA-Z0-9.-]+)+(:[0-9]+)?$ ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_addr_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_addr_value "$raw_val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # 5c. Value looks like a file path → tail-preserving path masking
    if [[ "$raw_val" == "/"* ]] || [[ "$raw_val" =~ ^[A-Za-z]:\\ ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_path_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_path_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_path_value "$raw_val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi

    # 5d. Value looks like a resource identifier (3+ delimiter-separated tokens)
    if [[ "$raw_val" =~ ^[a-zA-Z0-9]+[-_][a-zA-Z0-9]+([-_][a-zA-Z0-9]+)+$ ]]; then
      local raw masked suffix
      if [[ "$val" =~ ^\"([^\"]*)\"(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_identifier_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}\"${masked}\"${suffix}"
      elif [[ "$val" =~ ^\'([^\']*)\'(.*)$ ]]; then
        raw="${BASH_REMATCH[1]}"; suffix="${BASH_REMATCH[2]}"
        masked=$(mask_identifier_value "$raw")
        echo "${indent}${key}${sp1}=${sp2}'${masked}'${suffix}"
      else
        masked=$(mask_identifier_value "$raw_val")
        echo "${indent}${key}${sp1}=${sp2}${masked}"
      fi
      return 0
    fi
  fi

  echo "$line"
}

# sanitize_config <file>
# Reads a config file line by line and sanitizes each line.
# Tracks block/stanza context so that 'path' inside a 'secret' stanza is
# fully redacted rather than tail-preserved.
sanitize_config() {
  local file="$1"

  # Context tracking for secret stanzas.
  # _in_secret  : 1 while processing lines inside a 'secret "..." { }' block.
  # _secret_depth: brace nesting depth relative to the opening '{' of the stanza.
  # _pending_secret: 1 after seeing 'secret "..."' on a line with no '{' yet
  #                  (handles the rare case where the opening brace is on the next line).
  local _in_secret=0
  local _secret_depth=0
  local _pending_secret=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Count unquoted-ish braces on this line (good enough for standard HCL config).
    local _opens _closes
    _opens=$(printf '%s' "$line" | tr -cd '{' | wc -c)
    _closes=$(printf '%s' "$line" | tr -cd '}' | wc -c)

    if [[ $_in_secret -eq 0 && $_pending_secret -eq 0 ]]; then
      # Look for the start of a 'secret "<name>"' stanza.
      # Pattern: optional leading whitespace, then the word 'secret' followed by whitespace.
      if [[ "$line" =~ ^[[:space:]]*secret[[:space:]]+ ]]; then
        if [[ $_opens -gt 0 ]]; then
          # Opening brace is on this line.
          _in_secret=1
          _secret_depth=$(( _opens - _closes ))
          [[ $_secret_depth -le 0 ]] && _in_secret=0 && _secret_depth=0
        else
          # No opening brace yet — wait for it on the next line.
          _pending_secret=1
        fi
      fi
    elif [[ $_pending_secret -eq 1 ]]; then
      # Waiting for the opening brace of the secret stanza.
      if [[ $_opens -gt 0 ]]; then
        _pending_secret=0
        _in_secret=1
        _secret_depth=$(( _opens - _closes ))
        [[ $_secret_depth -le 0 ]] && _in_secret=0 && _secret_depth=0
      fi
    else
      # Already inside a secret stanza — update the brace depth.
      _secret_depth=$(( _secret_depth + _opens - _closes ))
      [[ $_secret_depth -le 0 ]] && _in_secret=0 && _secret_depth=0
    fi

    sanitize_line "$line" "$_in_secret"
  done < "$file"
}

show_sanitize_help() {
  cat << EOF
Usage:
  vaultx sanitize -config=<file> [-out=<file>]
  vaultx sanitize <file>         [-out=<file>]

Sanitize sensitive values in a Vault config file so it can be safely shared
with support teams. Outputs to stdout by default.

ARGUMENTS:
  <file>              Path to the config file to sanitize (positional)
  -config=<file>      Path to the config file to sanitize (flag form)

OPTIONS:
  -out=<file>         Write sanitized output to FILE instead of stdout
  -help               Show this help message

POLICY MATRIX:

  secret/full-redact  — replaced with ***REDACTED***
    token, auth_token, api_key, secret, client_secret,
    kms_key, kms_key_id, private_key, password, access_key, secret_key
    (case-insensitive; generic fallback also redacts keys whose name
     contains token/secret/password/passwd/credential or ends with _key)

  endpoint/anonymize  — host masked, scheme/port/path preserved
    vault_addr, api_addr, cluster_addr, cluster_address, address,
    redirect_addr  (case-insensitive)

    IPv4 host:       169.182.4.100               ->  x.x.x.100
    DNS 2-label:     hashicorp.com               ->  hashicorp.com  (unchanged)
    DNS 3-label:     vault.hashicorp.com         ->  x.hashicorp.com
    DNS 4-label:     prd.ec2.hashicorp.com       ->  x.x.hashicorp.com
    URL:             https://vault.hashicorp.com:8200/v1
                                                 ->  https://x.hashicorp.com:8200/v1
    host:port:       prd.ec2.hashicorp.com:8201  ->  x.x.hashicorp.com:8201
    Loopback:        localhost / 127.0.0.1 / 0.0.0.0  ->  unchanged
    IPv6:            [2001:db8::1]               ->  [x:x::1]
                     (loopback [::1] and wildcard [::] preserved)

  path/tail-preserve  — leading directories masked, last two segments kept
    path, tls_cert_file, tls_key_file, tls_client_ca_file, tls_ca_file,
    ca_cert, ca_path, cert_file, key_file, pid_file, log_file,
    file_path, audit_log_path, config_file  (case-insensitive)

    /etc/ssl/vault/server.key   ->  .../.../vault/server.key
    /opt/vault/data             ->  .../vault/data
    C:\vault\tls\server.key     ->  ...\tls\server.key

  identifier/token-mask  — leading tokens masked, suffix kept
    cluster_name, node_id, node_name, region, availability_zone

    vault-prod-eu-west-1        ->  x-x-eu-west-1
    us-east-1                   ->  x-east-1

  generic-fallback  — applied to all other keys:
    key name implies secret     ->  ***REDACTED***
    value is URL / IP           ->  endpoint/anonymize policy
    value is absolute path      ->  path/tail-preserve policy
    value is multi-token ident  ->  identifier/token-mask policy (3+ tokens)

NOTE: Log sanitization is planned for a future release.

EXAMPLES:
  vaultx sanitize -config=config.hcl
  vaultx sanitize config.hcl
  vaultx sanitize -config=config.hcl -out=sanitized.hcl
EOF
}

cmd_sanitize() {
  local config_file="" out_file=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -config=*|--config=*) config_file="${1#*=}" ;;
      -config|--config) shift; config_file="$1" ;;
      -out=*|--out=*) out_file="${1#*=}" ;;
      -out|--out) shift; out_file="$1" ;;
      -help|--help) show_sanitize_help; exit 0 ;;
      -*)
        echo "ERROR: Unknown sanitize flag: $1" >&2
        show_sanitize_help >&2
        exit 1
        ;;
      *)
        if [[ -z "$config_file" ]]; then
          config_file="$1"
        else
          echo "ERROR: Unexpected argument: $1" >&2
          show_sanitize_help >&2
          exit 1
        fi
        ;;
    esac
    shift
  done

  if [[ -z "$config_file" ]]; then
    echo "ERROR: No config file specified." >&2
    show_sanitize_help >&2
    exit 1
  fi

  if [[ ! -e "$config_file" ]]; then
    echo "ERROR: Config file not found: $config_file" >&2
    exit 1
  fi

  if [[ ! -f "$config_file" ]]; then
    echo "ERROR: Not a regular file: $config_file" >&2
    exit 1
  fi

  if [[ ! -r "$config_file" ]]; then
    echo "ERROR: Config file is not readable: $config_file" >&2
    exit 1
  fi

  if [[ -n "$out_file" ]]; then
    sanitize_config "$config_file" > "$out_file"
    echo "Sanitized config written to: $out_file" >&2
  else
    sanitize_config "$config_file"
  fi
}

# Handle subcommands before global flag parsing
if [[ "${1:-}" == "sanitize" ]]; then
  shift
  cmd_sanitize "$@"
  exit $?
fi

